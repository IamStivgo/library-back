{
   "name": "library-management-backend",
   "version": "1.0.0",
   "main": "dist/infrastructure/api/Server.js",
   "description": "Backend for library management system with hexagonal architecture",
   "license": "MIT",
   "private": true,
   "author": {
      "name": "Stiven"
   },
   "overrides": {
      "@types/babel__traverse": "7.18.2"
   },
   "scripts": {
      "build": "rimraf dist && tsc -p tsconfig.build.json",
      "lint": "eslint . --ext .ts --fix || true",
      "format": "prettier --write \"./src/**/*.ts\"",
      "format-check": "prettier --list-different \"./src/**/*.ts\"",
      "dev": "tsc-watch -p tsconfig.build.json --onSuccess \"node dist/infrastructure/api/Server.js\"",
      "start": "node dist/infrastructure/api/Server.js",
      "start:debug": "tsc-watch -p tsconfig.build.json --onSuccess \"node --inspect-brk dist/infrastructure/api/Server.js\"",
      "test": "jest --color --verbose --no-cache",
      "coverage": "jest --coverage",
      "migrate:run": "ts-node -r tsconfig-paths/register src/cli/migrate.ts run",
      "migrate:status": "ts-node -r tsconfig-paths/register src/cli/migrate.ts status",
      "migrate:rollback": "ts-node -r tsconfig-paths/register src/cli/migrate.ts rollback",
      "migrate:mark-executed": "ts-node -r tsconfig-paths/register src/cli/mark-migrations-executed.ts",
      "migrate:reset": "ts-node -r tsconfig-paths/register src/cli/reset-migration.ts",
      "user:update-password": "ts-node -r tsconfig-paths/register src/cli/update-password.ts"
   },
   "dependencies": {
      "@azure/msal-node": "^5.1.1",
      "@fastify/cors": "^7.0.0",
      "@fastify/formbody": "^6.0.0",
      "@fastify/helmet": "^8.0.0",
      "@google/generative-ai": "^0.24.1",
      "@types/bcryptjs": "^2.4.6",
      "@types/jsonwebtoken": "^9.0.10",
      "@types/passport": "^1.0.17",
      "@types/passport-google-oauth20": "^2.0.17",
      "@types/passport-jwt": "^4.0.1",
      "bcryptjs": "^3.0.3",
      "dotenv": "^16.0.0",
      "fastify": "^3.28.0",
      "google-auth-library": "^10.6.2",
      "inversify": "6.0.1",
      "joi": "17.6.0",
      "jsonwebtoken": "^9.0.3",
      "module-alias": "2.2.2",
      "moment-timezone": "^0.6.0",
      "passport": "^0.7.0",
      "passport-github2": "^0.1.12",
      "passport-google-oauth20": "^2.0.0",
      "passport-jwt": "^4.0.1",
      "passport-microsoft": "^2.1.0",
      "pg": "^8.11.3",
      "reflect-metadata": "0.1.13",
      "uuid": "^11.1.0"
   },
   "devDependencies": {
      "@types/jest": "27.4.1",
      "@types/node": "17.0.29",
      "@types/pg": "^8.10.0",
      "@types/uuid": "^10.0.0",
      "@typescript-eslint/eslint-plugin": "5.21.0",
      "@typescript-eslint/parser": "5.21.0",
      "eslint": "8.14.0",
      "eslint-config-prettier": "8.5.0",
      "eslint-plugin-prettier": "4.0.0",
      "jest": "29",
      "prettier": "2.6.2",
      "rimraf": "3.0.2",
      "ts-jest": "29",
      "ts-node": "10.7.0",
      "tsc-watch": "5.0.3",
      "tsconfig-paths": "^4.2.0",
      "typescript": "4.6.3"
   },
   "_moduleAliases": {
      "@application": "dist/application",
      "@domain": "dist/domain",
      "@infrastructure": "dist/infrastructure",
      "@configuration": "dist/configuration",
      "@util": "dist/util"
   }
}
