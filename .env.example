# Backend Environment Variables
# Copy this file as .env and configure the values

# Node Environment
NODE_ENV=development

# Server Configuration
HOST=0.0.0.0
PORT=5000
PREFIX_URL=/api

# CORS Configuration
CORS_ORIGIN=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=library_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_key_here_minimum_32_characters
JWT_REFRESH_SECRET=your_very_secure_refresh_secret_key_here_minimum_32_characters
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth Configuration
# Get your credentials at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tester-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tester-google-client-secret

